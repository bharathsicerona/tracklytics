# Tracklytics – Environment Variables
# Copy this file to .env and fill in your values.
# .env is never committed to version control.

# Gmail account used to send invite emails to new users
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password   # Generate at myaccount.google.com → Security → App Passwords

# Secret key used to sign session cookies — use any long random string
SECRET_KEY=change-this-to-a-long-random-string

# Your email address — the admin account is created with this on first init_db.py run
ADMIN_EMAIL=your_email@example.com

# ── DATABASE ─────────────────────────────────────────────────
# No database env vars needed. Tracklytics uses SQLite.
# The DB file is created automatically at: tracklytics.db in the project root.
# To initialise: python init_db.py
